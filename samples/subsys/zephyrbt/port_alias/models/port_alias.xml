<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="btree_port_alias">
  <BehaviorTree ID="btree_port_alias">
    <Delay delay_msec="1000">
      <Sequence>
        <WriteValue value_port="{variable_a}"/>
        <WriteValue value_port="{variable_b}"/>
        <ReadValue value_port="{variable_a}"/>
        <ReadValue value_port="{variable_b}"/>
      </Sequence>
    </Delay>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="ReadValue"
            editable="true">
      <input_port name="value_port"
                  default="{value_port}"/>
    </Action>
    <Action ID="WriteValue"
            editable="true">
      <output_port name="value_port"
                   default="{value_port}"/>
    </Action>
  </TreeNodesModel>

</root>
